---
import { withBase } from '../lib/content'
---

<header class="site-header">
  <a class="brand" href={withBase()}>
    <span class="brand-mark" aria-hidden="true"><span>GM</span></span>
    <span>
      <strong>God-Museum</strong>
      <small>众神殿</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="主导航">
    <a href={withBase('halls')}>大殿</a>
    <a href={withBase('deities')}>神座</a>
    <a href={withBase('civilizations')}>文明</a>
    <a href={withBase('chronicles')}>编年史</a>
    <a href={withBase('sources')}>来源</a>
  </nav>

  <div class="header-actions">
    <a class="mobile-catalog" href={withBase('catalog')}>目录</a>
    <button class="text-button" type="button" data-search-open aria-haspopup="dialog">
      搜索
      <kbd>/</kbd>
    </button>
    <a
      class="github-link"
      href="https://github.com/realchendahuang/god-museum"
      target="_blank"
      rel="noreferrer"
    >
      GitHub
      <svg aria-hidden="true" viewBox="0 0 16 16">
        <path d="M5 11 11 5M6 5h5v5" />
      </svg>
    </a>
  </div>
</header>
