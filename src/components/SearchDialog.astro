---
import { getCollection } from 'astro:content'
import {
  type DocEntry,
  entrySummary,
  entryTitle,
  entryTypeLabel,
  plainSearchText,
  routeForEntry
} from '../lib/content'

const docs: DocEntry[] = await getCollection('docs')
const records = docs.map(entry => ({
  title: entryTitle(entry),
  type: entryTypeLabel(entry),
  summary: entrySummary(entry),
  href: routeForEntry(entry),
  search: plainSearchText(entry)
}))
const serialized = JSON.stringify(records).replaceAll('<', '\\u003c')
---

<dialog class="search-dialog" id="site-search" aria-labelledby="search-title">
  <div class="search-shell">
    <div class="search-heading">
      <div>
        <p>馆藏检索</p>
        <h2 id="search-title">搜索众神殿</h2>
      </div>
      <button type="button" class="search-close" data-search-close aria-label="关闭搜索">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="m6 6 12 12M18 6 6 18" />
        </svg>
      </button>
    </div>

    <label class="search-field">
      <span class="sr-only">输入神名、权柄、文明或原典</span>
      <input
        id="global-search-input"
        type="search"
        autocomplete="off"
        placeholder="输入神名、权柄、文明或原典…"
      />
      <span class="search-count" data-search-count></span>
    </label>

    <div class="search-results" data-search-results aria-live="polite"></div>
  </div>
</dialog>

<script is:inline type="application/json" id="search-records" set:html={serialized}></script>

<script>
  const dialog = document.querySelector('#site-search')
  const input = document.querySelector('#global-search-input')
  const results = document.querySelector('[data-search-results]')
  const count = document.querySelector('[data-search-count]')
  const source = document.querySelector('#search-records')
  interface SearchRecord {
    title: string
    type: string
    summary: string
    href: string
    search: string
  }
  const records: SearchRecord[] = source ? JSON.parse(source.textContent || '[]') : []

  function renderSearch(query = '') {
    if (!(results instanceof HTMLElement) || !(count instanceof HTMLElement)) return
    const normalized = query.trim().toLocaleLowerCase('zh-CN')
    const matches = (normalized
      ? records.filter(record => record.search.includes(normalized))
      : records
    ).slice(0, 12)

    results.replaceChildren()
    count.textContent = normalized ? `${matches.length} 项` : ''

    if (!matches.length) {
      const empty = document.createElement('p')
      empty.className = 'search-empty'
      empty.textContent = '没有找到对应馆藏。试试神名、文明或权柄。'
      results.append(empty)
      return
    }

    matches.forEach((record, index) => {
      const link = document.createElement('a')
      link.className = 'search-result'
      link.href = record.href

      const number = document.createElement('span')
      number.className = 'search-result-number'
      number.textContent = String(index + 1).padStart(2, '0')

      const body = document.createElement('span')
      body.className = 'search-result-body'

      const meta = document.createElement('small')
      meta.textContent = record.type
      const title = document.createElement('strong')
      title.textContent = record.title
      const summary = document.createElement('span')
      summary.textContent = record.summary

      body.append(meta, title, summary)
      link.append(number, body)
      results.append(link)
    })
  }

  function openSearch() {
    if (!(dialog instanceof HTMLDialogElement) || !(input instanceof HTMLInputElement)) return
    if (!dialog.open) dialog.showModal()
    renderSearch(input.value)
    requestAnimationFrame(() => input.focus())
  }

  document.querySelectorAll('[data-search-open]').forEach(button => {
    button.addEventListener('click', openSearch)
  })

  document.querySelector('[data-search-close]')?.addEventListener('click', () => {
    if (dialog instanceof HTMLDialogElement) dialog.close()
  })

  input?.addEventListener('input', event => {
    if (event.target instanceof HTMLInputElement) renderSearch(event.target.value)
  })

  dialog?.addEventListener('click', event => {
    if (event.target === dialog && dialog instanceof HTMLDialogElement) dialog.close()
  })

  document.addEventListener('keydown', event => {
    const target = event.target
    const isTyping = target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement
    if (event.key === '/' && !isTyping) {
      event.preventDefault()
      openSearch()
    }
  })
</script>
